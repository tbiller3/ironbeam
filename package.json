{
  "name": "ironbeam",
  "version": "2.0.0",
  "description": "IRONBEAM Technologies — Unrestricted Transfer Protocol",
  "main": "src/main/main.js",
  "author": "IRONBEAM Technologies",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.2",
    "multicast-dns": "^7.2.5",
    "node-forge": "^1.3.1",
    "qrcode": "^1.5.4",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "ca.ironbeam.app",
    "productName": "IRONBEAM",
    "copyright": "Copyright 2025 IRONBEAM Technologies",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-forge/**/*"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "server-core.js",
      "phone-app/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/app-builder-lib/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/7zip-bin/linux/**/*",
      "!node_modules/7zip-bin/mac/**/*",
      "!node_modules/app-builder-bin/linux/**/*",
      "!node_modules/app-builder-bin/mac/**/*",
      "!**/*.map",
      "!**/test/**/*",
      "!**/tests/**/*",
      "!**/docs/**/*",
      "!**/example/**/*",
      "!**/examples/**/*",
      "!**/.travis.yml",
      "!**/README.md",
      "!**/CHANGELOG.md",
      "!**/HISTORY.md"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker",
      "artifactName": "IRONBEAM-Setup-${version}.exe",
      "publisherName": "IRONBEAM Technologies"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "IRONBEAM",
      "license": "build/license.txt",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "menuCategory": "IRONBEAM Technologies",
      "include": "build/installer.nsh"
    }
  }
}
